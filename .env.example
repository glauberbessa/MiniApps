# NextAuth
# Em produção, use a URL do seu site (ex: https://seu-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000
# Gere com: openssl rand -base64 32
# AUTH_SECRET é o padrão do NextAuth v5, mas NEXTAUTH_SECRET também funciona
AUTH_SECRET=sua-chave-secreta-aqui

# Google OAuth
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# Database (PostgreSQL via Supabase)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Get credentials from: https://supabase.com/dashboard/project/[project-id]/settings/database
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# E-mail (Resend)
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: E-mail de origem (padrão: MiniApps <noreply@resend.dev>)
# Para domínio próprio, configure em https://resend.com/domains
EMAIL_FROM=MiniApps <noreply@resend.dev>

# URL da aplicação (para links em e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
